{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "inox/inox",
    "type": "project",
    "description": "The modern PHP CMS that doesn't rust.",
    "keywords": ["cms", "laravel", "inox"],
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "setup": [
            "composer install --working-dir=core",
            "@php -r \"copy('core/.env.example', '.env');\"",
            "@php core/artisan key:generate",
            "@php core/artisan migrate --force"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "@php core/artisan serve"
        ],
        "test": [
            "@php core/artisan test"
        ]
    }
}
