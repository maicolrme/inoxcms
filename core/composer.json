{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "inox/inox",
    "type": "project",
    "description": "The modern PHP CMS that doesn't rust.",
    "keywords": [
        "cms",
        "laravel",
        "inox"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.8",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Inox\\Seo\\": "modules/inox/seo/src",
            "Inox\\Storage\\": "modules/inox/storage/src",
            "Inox\\Api\\": "modules/inox/api/src",
            "Inox\\Ai\\": "modules/inox/ai/src",
            "Inox\\Ecommerce\\": "modules/inox/ecommerce/src",
            "Inox\\SchemaStudio\\": "modules/inox/schema-studio/src",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php core/artisan key:generate",
            "@php core/artisan migrate --force"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "@php core/artisan serve"
        ],
        "test": [
            "@php core/artisan config:clear --ansi @no_additional_args",
            "@php core/artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php core/artisan package:discover --ansi --no-interaction"
        ],
        "post-update-cmd": [
            "@php core/artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php core/artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php core/artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
